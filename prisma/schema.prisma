generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  MODERATOR
}

enum ElectionStatus {
  UPCOMING
  ACTIVE
  COUNTING
  COMPLETED
}

enum NotificationChannel {
  APP
  EMAIL
  SMS
  PUSH
}

model User {
  id            String         @id @default(cuid())
  name          String?
  email         String         @unique
  emailVerified DateTime?
  image         String?
  role          Role           @default(USER)
  region        String?
  language      String         @default("en")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  accounts      Account[]
  sessions      Session[]
  chatHistory   ChatHistory[]
  voterQueries  VoterQuery[]
  notifications Notification[]
  adminLogs     AdminLog[]     @relation("AdminActor")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Election {
  id          String           @id @default(cuid())
  title       String
  region      String
  country     String           @default("India")
  status      ElectionStatus   @default(UPCOMING)
  description String
  startDate   DateTime
  endDate     DateTime
  rules       Json
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  candidates  Candidate[]
  timelines   ElectionEvent[]
  booths      PollingBooth[]
  news        NewsArticle[]
}

model ElectionEvent {
  id          String   @id @default(cuid())
  electionId  String
  title       String
  phase       String
  region      String
  description String
  startsAt    DateTime
  endsAt      DateTime?
  sourceUrl   String?
  election    Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@index([region, startsAt])
}

model Party {
  id          String      @id @default(cuid())
  name        String
  shortName   String      @unique
  ideology    String
  manifesto   String      @db.Text
  color       String
  website     String?
  candidates  Candidate[]
  performance PartyPerformance[]
}

model Candidate {
  id                String      @id @default(cuid())
  electionId         String
  partyId            String
  name              String
  constituency      String
  region            String
  age               Int
  education         String
  profession        String
  criminalCases     Int         @default(0)
  declaredAssets    Decimal     @db.Decimal(14, 2)
  publicPriorities  String[]
  affidavitUrl      String?
  election          Election    @relation(fields: [electionId], references: [id], onDelete: Cascade)
  party             Party       @relation(fields: [partyId], references: [id], onDelete: Restrict)
}

model PartyPerformance {
  id       String @id @default(cuid())
  partyId  String
  year     Int
  seats    Int
  voteShare Float
  party    Party  @relation(fields: [partyId], references: [id], onDelete: Cascade)
}

model PollingBooth {
  id              String   @id @default(cuid())
  electionId       String
  name            String
  address         String
  region          String
  pinCode         String
  latitude        Float
  longitude       Float
  accessibility   Boolean  @default(true)
  queueLevel      Int      @default(2)
  openingTime     String
  closingTime     String
  election        Election @relation(fields: [electionId], references: [id], onDelete: Cascade)

  @@index([region, pinCode])
}

model Notification {
  id        String              @id @default(cuid())
  userId    String?
  title     String
  body      String
  channel   NotificationChannel @default(APP)
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime            @default(now())
  user      User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model ChatHistory {
  id          String   @id @default(cuid())
  userId      String?
  question    String   @db.Text
  answer      String   @db.Text
  intent      String
  language    String   @default("en")
  sources     Json?
  createdAt   DateTime @default(now())
  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model NewsArticle {
  id             String   @id @default(cuid())
  electionId      String?
  title          String
  summary        String   @db.Text
  source         String
  sourceUrl      String
  region         String
  verified       Boolean  @default(false)
  sentiment      String
  misinformation Float    @default(0)
  publishedAt    DateTime
  election       Election? @relation(fields: [electionId], references: [id], onDelete: SetNull)
}

model VoterQuery {
  id                  String   @id @default(cuid())
  userId              String?
  age                 Int
  citizenship         String
  region              String
  hasGovernmentId     Boolean
  isRegistered        Boolean
  eligible            Boolean
  missingRequirements String[]
  createdAt           DateTime @default(now())
  user                User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model AdminLog {
  id        String   @id @default(cuid())
  actorId   String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User?    @relation("AdminActor", fields: [actorId], references: [id], onDelete: SetNull)
}
